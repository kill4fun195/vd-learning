# Application
APP_NAME=FastAPI User Service
DEBUG=true

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AWS RDS (PostgreSQL) — or local Postgres from docker-compose
DATABASE_URL=postgresql://xxxxxx:xxxxxx@docker-dev-db-1:5432/learning_local

# AWS S3 (or MinIO for local docker-compose)
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxxxx
S3_BUCKET_NAME=xxxxx
AWS_REGION=xxxxxxxxx

# Leave empty for real AWS S3. For MinIO / LocalStack set both:
# S3_ENDPOINT_URL=http://localhost:9000
# S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ENDPOINT_URL=
S3_PUBLIC_ENDPOINT_URL=